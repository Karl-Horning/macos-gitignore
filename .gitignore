# macOS system files
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.com.apple.metadata:*

# Temporary/backup files (general)
*~
*.bak
*.tmp
*.old
*.swp
*.swo
*.swn
*.asd
*.orig

# Word/Excel temp files
~$*
*.wbk         # Word backup
*.xlk         # Excel backup
*.lock        # Office/other file lock indicators — broad, review before use in code projects

# Affinity Designer, Photo, and Publisher autosave files
*.autosave
*.afdesign-preview
*.afphoto-preview
*.afpub-preview
